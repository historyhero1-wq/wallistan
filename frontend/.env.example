# ── WooCommerce REST API (server-only — never expose consumer secret) ─────────
# WooCommerce → Settings → Advanced → REST API → Add key (Read/Write)
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxx

# Set true after WooCommerce vars are configured
VITE_WOOCOMMERCE_ENABLED=true

# ── Site ──────────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://wallistan.pk

# Optional: Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
