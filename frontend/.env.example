# ── WooCommerce REST API (server-only — never expose consumer secret) ─────────
# WooCommerce → Settings → Advanced → REST API → Add key (Read/Write)
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxx

# Set true after WooCommerce vars are configured
VITE_WOOCOMMERCE_ENABLED=false

# ── Site ──────────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://wallistan.pk

# Optional: Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Wallistan Custom PHP Backend ──────────────────────────────────────────────
# PRODUCTION: Your InfinityFree backend URL (no trailing slash)
# Example:    STORE_API_URL=https://wallistan.epizy.com/api
#
# LOCAL DEV:  STORE_API_URL=http://localhost/wallistan/backend/Backend/api
#
# SERVER-SIDE ONLY: This is never sent to the browser.
# On Vercel: set in Project Settings → Environment Variables (Production).
STORE_API_URL=https://YOUR_INFINITYFREE_DOMAIN/api

# Set true to enable the Wallistan store (products, checkout, orders)
VITE_STORE_ENABLED=true
